{
  "name": "jobstacker-desktop",
  "version": "1.0.0",
  "description": "JobStacker - Customer quotes for tradespeople",
  "main": "main.js",
  "author": "JobStacker",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.jobstacker.app",
    "productName": "JobStacker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "artifactName": "JobStacker-${version}-mac.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "JobStacker-${version}-win-setup.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "artifactName": "JobStacker-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "morganthompson",
      "repo": "tradely"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0"
  }
}
