# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs for each plan tier
NEXT_PUBLIC_STRIPE_PRICE_SOLO_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_...

# ── AI ──
# Groq (free) — https://console.groq.com
GROQ_API_KEY=gsk_...
AI_MODEL=llama-3.3-70b-versatile
# OR OpenAI
# OPENAI_API_KEY=sk-proj-...
# AI_MODEL=gpt-4o-mini

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_RATE_LIMIT=10
AI_RATE_WINDOW_MS=60000

# ── Email (Resend) ──
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
# Verified sender email (must be verified in Resend)
EMAIL_FROM=quotes@jobstacker.app

# ── Desktop Downloads ──
# URL for the macOS .dmg download (default redirects to catbox.moe)
DMG_DOWNLOAD_URL=https://files.catbox.moe/3k6f4o.dmg
# URL for the Windows .exe download (optional — falls back to install guide)
EXE_DOWNLOAD_URL=
